{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/admission", "destination": "/api/admission" },
    { "source": "/api/contact",   "destination": "/api/contact"   },
    { "source": "/(.*)",          "destination": "/index.html"    }
  ]
}
